{
  "manifest_version": 3,
  "name": "Video Speed Control",
  "version": "1.0.0",
  "description": "Minimal popup to control video playback speed with adjustable max range.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Speed Control"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
